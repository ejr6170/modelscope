{
  "name": "modelscope",
  "version": "1.0.0",
  "description": "Real-time Claude Code session observatory",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "parse": "node src/parser.js",
    "server": "node server.js",
    "dev": "next dev --port 3777",
    "build": "next build",
    "electron": "electron .",
    "start": "concurrently \"npm run server\" \"npm run dev\" \"sleep 3 && npm run electron\"",
    "dist": "next build && electron-builder",
    "release": "next build && electron-builder --publish always"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ejr6170/modelscope.git"
  },
  "homepage": "https://github.com/ejr6170/modelscope",
  "build": {
    "appId": "com.modelscope.app",
    "productName": "ModelScope",
    "directories": {
      "output": "ModelScope-Build"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/logo.png",
        "to": "logo.png"
      },
      {
        "from": "server.js",
        "to": "server.js"
      },
      {
        "from": "src",
        "to": "src"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "ejr6170",
      "repo": "modelscope"
    }
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "framer-motion": "^11.0.0",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/react": "^19.0.0",
    "@types/node": "^22.0.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "concurrently": "^9.0.0"
  }
}
